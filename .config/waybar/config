{
  "layer": "top",
  "position": "top",
    "margin-top" : 10,
    "margin-left": 10,
    "margin-right": 10,
    "height" : 32,
    "modules-left": [
    	"hyprland/workspaces",
	"tray",
        "custom/cpu_freq",
	"cpu",
	"memory",
    ],
    "modules-center": [
    ],
    "modules-right": [
        "pulseaudio",
        "battery",
 	"power-profiles-daemon",
        "backlight",
	"hyprland/language",
    	"clock",
	"custom/vpn",
        "network",
        "custom/wlogout"
    ],
    "hyprland/workspaces": {
      "format": "{icon}",
      "on-click": "activate",
      "format-icons": {
        "active": "пДС",
      },
      "sort-by-number": true,
      "persistent-workspaces": {
        "*": 4, // 5 workspaces by default on every monitor
        "HDMI-A-1": 3 // but only three on HDMI-A-1
      },
    },
    "hyprland/language": {
      "format": "{}",
      "format-en": "EN",
      "format-ru": "RU"
    },
    "clock": {
      "format": "пАЧ {:%H:%M | пД≥ %d.%m}",
      "tooltip-format": "пД≥  <big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
      "format-alt": "пД≥ {:%d.%m.%Y}"
    },
    "cpu": {
      "format": "пЛЫ {usage}%",
      "tooltip": true
    },
    "memory": {
      "format": "пФЄ {used:0.2f} GB",
      "tooltip": true
    },
    "battery": {
      "states": {
        "warning": 30,
        "critical": 15
      },
      "format": "{icon} {capacity}%",
      "format-full": "{icon} {capacity}%",
      "format-charging": "оХЫ {capacity}%",
      "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"]
    },
    "network": {
      "format-wifi": "пЗЂ",
      "format-ethernet": "пЮЦ",
      "tooltip-format": "{ifname} via {gwaddr} пЮЦ",
      "format-linked": "{ifname} (No IP) пЮЦ",
      "format-disconnected": " вЪ†",
      "format-alt": "{ifname}: {ipaddr}/{cidr}"
    },
    "pulseaudio": {
      "format": "{icon} {volume}%",
      "format-bluetooth": "{volume}% {icon}пКФ {format_source}",
      "format-bluetooth-muted": "пЪ© {icon}пКФ {format_source}",
      "format-muted": "пЪ© Muted",
      "format-icons": {
        "headphone": "пА•",
        "hands-free": "пЦР",
        "headset": "пЦР",
        "phone": "пВХ",
        "portable": "пВХ",
        "car": "пЖє",
        "default": ["пА¶", "пАІ ", "пА® "]
      },
      "on-click": "pavucontrol"
    },
    "backlight": {
      "format": "пБВ {}%"
    },
    "custom/wlogout": {
      "exec": "echo пАС",
      "on-click": "sh -c wlogout",
      "tooltip": "–Т—Л—Е–Њ–і / –Я–µ—А–µ–Ј–∞–≥—А—Г–Ј–Ї–∞ / –С–ї–Њ–Ї–Є—А–Њ–≤–Ї–∞"
    },
     "custom/vpn": {
    	"exec": "~/.config/waybar/scripts/vpn-status.sh",
    	"interval": 5,
	"return-type": "json",
    	"on-click": "amneziavpn-bin",
    	"tooltip": "Amnezia VPN"
     },
     "tray": {
	"icon-size": 18,
	"spacing": 8,
	"show-passive-items": true
     },
     "custom/cpu_freq": {
	"exec": "awk '{printf \"%.2f\", $1/1000000}' /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq",
	"interval": 5,
	"format": "пЛЫ {} GHz"
      }
}
